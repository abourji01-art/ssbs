# ================================
# SSBS - Smart School Bus System
# Environment Variables Example
# Copy to .env and fill in values
# ================================

# ──────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────
POSTGRES_DB=ssbs_db
POSTGRES_USER=ssbs_user
POSTGRES_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# ──────────────────────────────────────
# Backend (Django)
# ──────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
APP_DEBUG=True

# ──────────────────────────────────────
# 42 Intra OAuth
# ──────────────────────────────────────
INTRA_42_CLIENT_ID=your-client-id
INTRA_42_CLIENT_SECRET=your-client-secret
INTRA_42_REDIRECT_URI=https://localhost:8443/api/v1/auth/42/callback/

# ──────────────────────────────────────
# Testing
# ──────────────────────────────────────
TESTING_MODE=true

# ──────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
